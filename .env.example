# Database Configuration
# For Render: This is auto-generated from the PostgreSQL database
# For local development, use your Neon or local PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/skill_map_db

# Session Secret - Generate a long random string for production
# Example: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=your_super_secret_key_here_change_in_production

# Server Port
PORT=3001

# Environment
NODE_ENV=development
